<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Pulse</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════
   TOKENS & THEMES
═══════════════════════════════════ */
:root{
  --fa:'Tajawal',sans-serif;
  --fe:'Space Grotesk',sans-serif;
  --ease:cubic-bezier(.4,0,.2,1);
  --spring:cubic-bezier(.34,1.56,.64,1);
}

/* NIGHT GOLD (default) */
[data-theme="gold"]{
  --bg:#0C0B08;--s0:#13120E;--s1:#1A1914;--s2:#25231C;--s3:#332F24;
  --br:rgba(255,210,100,0.08);
  --acc:#D4A843;--acc2:rgba(212,168,67,0.12);--acc3:rgba(212,168,67,0.06);
  --bme:#D4A843;--bme-t:#0C0B08;
  --bother:#1A1914;--bother-t:#EDE8DC;
  --t0:#F5F0E8;--t1:#EDE8DC;--t2:#A89B7E;--t3:#665E47;
  --bar:#13120E;--online:#4ADE80;--badge:#EF4444;
  --sh:0 2px 8px rgba(0,0,0,.5);--shlg:0 8px 32px rgba(0,0,0,.7);
}
/* MIDNIGHT */
[data-theme="midnight"]{
  --bg:#050508;--s0:#0D0D14;--s1:#12121C;--s2:#1A1A28;--s3:#242436;
  --br:rgba(120,110,255,0.08);
  --acc:#7C6FFF;--acc2:rgba(124,111,255,0.12);--acc3:rgba(124,111,255,0.06);
  --bme:#7C6FFF;--bme-t:#fff;
  --bother:#1A1A28;--bother-t:#E8E6FF;
  --t0:#F0EEFF;--t1:#E0DEFF;--t2:#8880B8;--t3:#4A4470;
  --bar:#0D0D14;--online:#34D399;--badge:#FF453A;
  --sh:0 2px 8px rgba(0,0,0,.6);--shlg:0 8px 32px rgba(0,0,0,.8);
}
/* AURORA */
[data-theme="aurora"]{
  --bg:#050F0A;--s0:#0A1A12;--s1:#0F2018;--s2:#152B20;--s3:#1C3829;
  --br:rgba(52,211,153,0.08);
  --acc:#34D399;--acc2:rgba(52,211,153,0.12);--acc3:rgba(52,211,153,0.06);
  --bme:#34D399;--bme-t:#050F0A;
  --bother:#152B20;--bother-t:#D1FAE5;
  --t0:#ECFDF5;--t1:#D1FAE5;--t2:#6EE7B7;--t3:#34706A;
  --bar:#0A1A12;--online:#4ADE80;--badge:#F59E0B;
  --sh:0 2px 8px rgba(0,0,0,.5);--shlg:0 8px 32px rgba(0,0,0,.7);
}
/* ROSE */
[data-theme="rose"]{
  --bg:#FAFAF8;--s0:#FFFFFF;--s1:#F9F8F6;--s2:#F2F0ED;--s3:#E8E4DF;
  --br:rgba(0,0,0,0.07);
  --acc:#C2410C;--acc2:rgba(194,65,12,0.08);--acc3:rgba(194,65,12,0.04);
  --bme:#C2410C;--bme-t:#fff;
  --bother:#F2F0ED;--bother-t:#1C1917;
  --t0:#1C1917;--t1:#292524;--t2:#78716C;--t3:#A8A29E;
  --bar:#FFFFFF;--online:#16A34A;--badge:#DC2626;
  --sh:0 1px 4px rgba(0,0,0,.08);--shlg:0 4px 20px rgba(0,0,0,.12);
}

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-font-smoothing:antialiased;}
html,body{height:100%;overflow:hidden;}
body{font-family:var(--fa);background:var(--bg);color:var(--t1);transition:background .3s,color .3s;}

/* ═══════════════════════════════════
   APP SHELL
═══════════════════════════════════ */
#shell{
  position:fixed;inset:0;
  max-width:430px;margin:0 auto;
  background:var(--s0);
  display:flex;flex-direction:column;
  overflow:hidden;
  box-shadow:0 0 80px rgba(0,0,0,0.4);
}

/* ═══════════════════════════════════
   LOGIN
═══════════════════════════════════ */
#loginScreen{
  position:absolute;inset:0;z-index:300;
  background:var(--bg);
  display:flex;flex-direction:column;
  overflow-y:auto;
}
#loginScreen.out{animation:loginOut .4s var(--ease) forwards;}
@keyframes loginOut{to{opacity:0;transform:scale(.96)}}

.login-bg{
  position:absolute;inset:0;overflow:hidden;pointer-events:none;
}
.login-bg::before{
  content:'';position:absolute;
  width:400px;height:400px;border-radius:50%;
  background:radial-gradient(circle,var(--acc) 0%,transparent 70%);
  top:-150px;left:50%;transform:translateX(-50%);
  opacity:.15;filter:blur(40px);
  animation:breathe 4s ease-in-out infinite;
}
@keyframes breathe{0%,100%{transform:translateX(-50%) scale(1)}50%{transform:translateX(-50%) scale(1.1)}}

.login-content{
  position:relative;z-index:1;
  flex:1;display:flex;flex-direction:column;
  align-items:center;padding:60px 28px 40px;
}
.login-mark{
  font-size:72px;line-height:1;margin-bottom:16px;
  animation:markPop .6s var(--spring);
}
@keyframes markPop{from{transform:scale(0) rotate(-20deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.login-brand{font-family:var(--fe);font-size:36px;font-weight:700;color:var(--t0);letter-spacing:-1px;margin-bottom:6px;}
.login-tagline{font-size:14px;color:var(--t2);margin-bottom:40px;letter-spacing:.3px;}

.login-card{
  width:100%;
  background:var(--s1);
  border:1px solid var(--br);
  border-radius:24px;
  padding:24px;
  box-shadow:var(--shlg);
}

.lf{margin-bottom:18px;}
.lf-label{font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.lf-row{display:flex;align-items:center;background:var(--s2);border:1.5px solid var(--br);border-radius:14px;overflow:hidden;transition:border-color .2s;}
.lf-row:focus-within{border-color:var(--acc);}
.lf-prefix{padding:13px 12px;font-size:13px;color:var(--t2);border-left:1px solid var(--br);white-space:nowrap;flex-shrink:0;}
.lf-input{flex:1;border:none;background:transparent;padding:13px 14px;font-family:var(--fa);font-size:15px;color:var(--t0);outline:none;direction:ltr;text-align:right;}
.lf-input::placeholder{color:var(--t3);}
.lf-solo{width:100%;border:none;background:var(--s2);border:1.5px solid var(--br);border-radius:14px;padding:13px 14px;font-family:var(--fa);font-size:15px;color:var(--t0);outline:none;transition:border-color .2s;}
.lf-solo:focus{border-color:var(--acc);}
.lf-solo::placeholder{color:var(--t3);}

.color-pick{display:flex;gap:9px;flex-wrap:wrap;padding:4px 0;}
.cp-dot{width:30px;height:30px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .18s;display:flex;align-items:center;justify-content:center;}
.cp-dot.on{border-color:var(--t0);transform:scale(1.18);}
.cp-dot.on::after{content:'✓';font-size:12px;color:#fff;font-weight:700;}

.login-btn{
  width:100%;padding:15px;margin-top:6px;
  background:var(--acc);color:var(--bme-t);
  border:none;border-radius:14px;
  font-family:var(--fa);font-size:16px;font-weight:700;
  cursor:pointer;letter-spacing:.3px;
  transition:all .2s;
  position:relative;overflow:hidden;
}
.login-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.15),transparent);
}
.login-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.3);}
.login-btn:active{transform:scale(.97);}

.login-terms{font-size:11px;color:var(--t3);text-align:center;margin-top:14px;line-height:1.8;}

/* ═══════════════════════════════════
   MAIN LAYOUT
═══════════════════════════════════ */
#mainWrap{
  flex:1;display:flex;flex-direction:column;
  overflow:hidden;
  opacity:0;animation:fadeUp .4s var(--ease) .1s forwards;
}
#mainWrap.visible{opacity:1;animation:none;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

/* slide panels */
.slide-wrap{
  flex:1;display:flex;width:200%;
  transition:transform .32s var(--ease);
  overflow:hidden;
}
.slide-wrap.open{transform:translateX(50%);}
.slide-wrap.drag{transition:none;}

.panel{width:50%;display:flex;flex-direction:column;overflow:hidden;}

/* ═══════════════════════════════════
   TOPBAR
═══════════════════════════════════ */
.topbar{
  background:var(--bar);
  padding:14px 16px 10px;
  display:flex;align-items:center;gap:10px;
  border-bottom:1px solid var(--br);
  flex-shrink:0;
  position:relative;
}
.topbar::after{
  content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--acc),transparent);
  opacity:.3;
}
.tb-title{font-family:var(--fe);font-size:17px;font-weight:700;color:var(--t0);flex:1;letter-spacing:-.3px;}
.tb-acts{display:flex;gap:7px;}
.tb-btn{
  width:34px;height:34px;border-radius:11px;
  background:var(--s2);border:1px solid var(--br);
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:15px;color:var(--t2);
  transition:all .18s;
}
.tb-btn:hover{background:var(--s3);color:var(--t0);}
.back-btn{
  width:34px;height:34px;border-radius:11px;
  background:var(--s2);border:1px solid var(--br);
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:18px;font-weight:300;color:var(--t1);
  transition:all .18s;flex-shrink:0;
}
.back-btn:hover{background:var(--s3);}

/* ═══════════════════════════════════
   SEARCH
═══════════════════════════════════ */
.search-wrap{
  background:var(--bar);padding:8px 14px 10px;
  border-bottom:1px solid var(--br);flex-shrink:0;
}
.search-inner{
  display:flex;align-items:center;gap:8px;
  background:var(--s2);border-radius:12px;
  padding:9px 13px;border:1px solid var(--br);
}
.search-inner input{flex:1;border:none;background:transparent;font-family:var(--fa);font-size:13px;color:var(--t1);outline:none;}
.search-inner input::placeholder{color:var(--t3);}

/* ═══════════════════════════════════
   AVATAR
═══════════════════════════════════ */
.av{
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-weight:800;flex-shrink:0;position:relative;overflow:hidden;
  background:var(--s2);transition:transform .2s var(--spring);
}
.av:active{transform:scale(.92);}
.av img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.av-s{width:42px;height:42px;font-size:16px;}
.av-m{width:48px;height:48px;font-size:18px;}
.av-l{width:80px;height:80px;font-size:30px;}
.av-xs{width:28px;height:28px;font-size:11px;}
.online-ring{
  position:absolute;bottom:0;right:0;
  width:12px;height:12px;border-radius:50%;
  background:var(--online);border:2.5px solid var(--s0);
}

/* ═══════════════════════════════════
   CHAT LIST
═══════════════════════════════════ */
.chat-list{flex:1;overflow-y:auto;}
.chat-list::-webkit-scrollbar{width:0;}

.chat-item{
  display:flex;align-items:center;gap:13px;
  padding:11px 16px;cursor:pointer;
  transition:background .15s;position:relative;
}
.chat-item::after{content:'';position:absolute;bottom:0;right:75px;left:0;height:1px;background:var(--br);}
.chat-item:hover{background:var(--s1);}
.chat-item.active{background:var(--acc3);}

.ci-info{flex:1;min-width:0;}
.ci-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;}
.ci-name{font-size:15px;font-weight:700;color:var(--t0);letter-spacing:-.2px;}
.ci-time{font-size:11px;color:var(--t3);}
.ci-prev{font-size:13px;color:var(--t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:180px;}

.badge{
  background:var(--badge);color:#fff;
  font-size:10px;font-weight:800;min-width:18px;height:18px;
  border-radius:9px;padding:0 4px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  font-family:var(--fe);
}

.empty-state{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:12px;padding:40px;
  animation:fadeUp .3s var(--ease);
}
.empty-ico{font-size:52px;opacity:.25;}
.empty-txt{font-size:14px;color:var(--t3);text-align:center;line-height:1.7;}

/* ═══════════════════════════════════
   CHAT VIEW
═══════════════════════════════════ */
.chat-view{
  flex:1;display:flex;flex-direction:column;
  background:var(--bg);overflow:hidden;
  position:relative;
}
/* subtle wallpaper pattern */
.chat-view::before{
  content:'';position:absolute;inset:0;
  background-image:radial-gradient(var(--br) 1px,transparent 1px);
  background-size:24px 24px;pointer-events:none;opacity:.6;
}

.chat-topbar{
  position:relative;z-index:2;
  background:var(--bar);padding:10px 14px;
  display:flex;align-items:center;gap:10px;
  border-bottom:1px solid var(--br);flex-shrink:0;
  box-shadow:var(--sh);
}
.chat-topbar::after{
  content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--acc),transparent);
  opacity:.3;
}
.ctb-info{flex:1;min-width:0;}
.ctb-name{font-size:15px;font-weight:700;color:var(--t0);}
.ctb-sub{font-size:11px;color:var(--t3);}
.ctb-acts{display:flex;gap:6px;}

.messages{
  flex:1;overflow-y:auto;padding:16px 14px;
  display:flex;flex-direction:column;gap:2px;
  position:relative;z-index:1;
}
.messages::-webkit-scrollbar{width:0;}

.date-chip{text-align:center;margin:10px 0 6px;}
.date-chip span{
  font-size:11px;color:var(--t3);
  background:var(--s2);
  padding:4px 14px;border-radius:20px;
  border:1px solid var(--br);
}

.msg-row{display:flex;align-items:flex-end;gap:7px;margin-bottom:1px;animation:msgIn .2s var(--spring);}
@keyframes msgIn{from{opacity:0;transform:translateY(8px) scale(.96)}to{opacity:1;transform:none}}
.msg-row.me{flex-direction:row;}
.msg-row.other{flex-direction:row-reverse;}

.msg-av{width:26px;height:26px;border-radius:50%;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.msg-av img{width:100%;height:100%;object-fit:cover;border-radius:50%;}

.msg-col{max-width:70%;display:flex;flex-direction:column;}
.msg-sn{font-size:10px;color:var(--t3);margin-bottom:3px;}
.msg-bw{display:flex;align-items:flex-end;gap:5px;}
.msg-row.me .msg-bw{flex-direction:row-reverse;}
.bub{
  padding:9px 13px;font-size:14px;line-height:1.55;
  word-break:break-word;max-width:260px;
}
.msg-row.me .bub{
  background:var(--bme);color:var(--bme-t);
  border-radius:18px 4px 18px 18px;
  font-weight:500;
}
.msg-row.other .bub{
  background:var(--bother);color:var(--bother-t);
  border-radius:4px 18px 18px 18px;
  box-shadow:var(--sh);
  border:1px solid var(--br);
}
.bub.emo{background:transparent!important;box-shadow:none!important;border:none!important;padding:2px 4px;font-size:34px;line-height:1;}
.msg-time{font-size:10px;color:var(--t3);white-space:nowrap;flex-shrink:0;padding-bottom:2px;}
.msg-read{font-size:10px;color:var(--acc);text-align:left;margin-top:2px;}

/* ── Translation bubble ── */
.msg-trans{
  font-size:12px;color:var(--t2);
  padding:5px 10px 6px;margin-top:2px;
  background:var(--s2);border-radius:10px;
  border:1px solid var(--br);
  display:flex;flex-direction:column;gap:2px;
  animation:fadeUp .2s var(--ease);
}
.msg-trans-txt{font-size:13px;color:var(--t1);line-height:1.5;}
.msg-trans-by{font-size:10px;color:var(--t3);display:flex;align-items:center;gap:4px;}

/* ── Quoted message ── */
.msg-quote{
  background:var(--s3);border-radius:8px;padding:6px 10px;
  margin-bottom:5px;border-right:3px solid var(--acc);
  font-size:12px;color:var(--t2);
  max-width:220px;overflow:hidden;
  white-space:nowrap;text-overflow:ellipsis;
}

/* ── Message context menu ── */
.msg-ctx{
  position:fixed;z-index:8000;
  background:var(--s2);border-radius:18px;
  border:1px solid var(--br);box-shadow:0 12px 40px rgba(0,0,0,.7);
  padding:8px;min-width:220px;
  animation:fadeUp .18s var(--spring);
  display:grid;grid-template-columns:repeat(5,1fr);gap:4px;
}
.msg-ctx-btn{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:10px 6px;border-radius:12px;cursor:pointer;
  background:transparent;border:none;
  font-family:var(--fa);color:var(--t1);font-size:11px;font-weight:600;
  transition:background .15s;
}
.msg-ctx-btn:hover{background:var(--s3);}
.msg-ctx-btn .ctx-ico{font-size:20px;line-height:1;}
.msg-ctx-btn.danger{color:#EF4444;}

/* ── Easy Mode large font ── */
body.easy-large{
  font-size:16px!important;
}
body.easy-large .bub{font-size:17px!important;}
body.easy-large .f-name,.easy-large .pname{font-size:18px!important;}
body.easy-large .nav-lbl{font-size:13px!important;}
body.easy-large .tb-btn{font-size:20px!important;width:40px;height:40px;}
body.easy-large .sh-btn{font-size:17px!important;padding:16px!important;}

/* ── Settings sheet ── */
.sett-row{
  display:flex;align-items:center;
  padding:14px 18px;border-bottom:1px solid var(--br);
  cursor:pointer;
}
.sett-ico{
  width:36px;height:36px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;margin-left:14px;flex-shrink:0;
}
.sett-lbl-wrap{flex:1;}
.sett-lbl{font-size:15px;font-weight:700;color:var(--t0);}
.sett-sub{font-size:12px;color:var(--t2);margin-top:2px;line-height:1.4;}
.sett-val{font-size:12px;color:var(--t3);margin-left:8px;}

/* ── Profile info list (WeChat style) ── */
.pinfo-grp{background:var(--s0);margin-bottom:8px;}
.pinfo-row{
  display:flex;align-items:center;
  padding:14px 18px;border-bottom:1px solid var(--br);cursor:pointer;
  transition:background .15s;
}
.pinfo-row:last-child{border-bottom:none;}
.pinfo-row:hover{background:var(--s1);}
.pinfo-key{font-size:15px;color:var(--t1);flex:1;}
.pinfo-val{font-size:14px;color:var(--t3);margin-left:8px;max-width:50%;text-align:left;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pinfo-arr{font-size:16px;color:var(--t3);margin-right:-4px;}

.typing-row{
  display:none;align-items:center;gap:9px;
  padding:7px 14px;flex-shrink:0;position:relative;z-index:1;
  font-size:12px;color:var(--t3);
}
.typing-row.show{display:flex;}
.dots span{
  width:5px;height:5px;border-radius:50%;
  background:var(--acc);display:inline-block;
  animation:dotBounce 1.2s infinite;margin:0 1.5px;
}
.dots span:nth-child(2){animation-delay:.2s;}
.dots span:nth-child(3){animation-delay:.4s;}
@keyframes dotBounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}

/* input area */
.input-area{
  background:var(--bar);border-top:1px solid var(--br);
  padding:8px 10px calc(8px + env(safe-area-inset-bottom));
  flex-shrink:0;position:relative;z-index:1;
}
.emoji-strip,.sticker-strip{
  display:none;flex-wrap:wrap;gap:4px;
  padding:10px 4px 8px;border-bottom:1px solid var(--br);margin-bottom:8px;
  max-height:120px;overflow-y:auto;
  animation:fadeUp .18s var(--ease);
}
.emoji-strip.on,.sticker-strip.on{display:flex;}
.emo-btn{font-size:22px;cursor:pointer;padding:3px;border:none;background:transparent;border-radius:6px;transition:transform .12s;line-height:1;}
.emo-btn:hover{transform:scale(1.35);}
.stk{font-size:34px;cursor:pointer;padding:5px 7px;border-radius:10px;background:var(--s2);border:1.5px solid transparent;transition:all .15s;line-height:1.15;}
.stk:hover{transform:scale(1.15);border-color:var(--acc);}

.input-row{display:flex;align-items:flex-end;gap:7px;}
.i-btn{
  width:36px;height:36px;border-radius:11px;
  background:var(--s2);border:1px solid var(--br);
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:15px;color:var(--t2);transition:all .18s;flex-shrink:0;
}
.i-btn:hover,.i-btn.on{background:var(--acc2);color:var(--acc);border-color:var(--acc);}
.msg-input{
  flex:1;background:var(--s2);border:1.5px solid var(--br);
  border-radius:20px;padding:9px 14px;
  font-family:var(--fa);font-size:14px;color:var(--t0);
  outline:none;resize:none;max-height:100px;line-height:1.5;
  transition:all .18s;
}
.msg-input:focus{border-color:var(--acc);background:var(--s1);}
.msg-input::placeholder{color:var(--t3);}
.send-btn{
  width:38px;height:38px;border-radius:50%;
  background:var(--acc);border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;color:var(--bme-t);
  transition:all .18s;flex-shrink:0;
  box-shadow:0 3px 12px rgba(0,0,0,.3);
}
.send-btn:hover{transform:scale(1.1);}
.send-btn:active{transform:scale(.9);}

/* ═══════════════════════════════════
   BOTTOM NAV
═══════════════════════════════════ */
.bot-nav{
  display:flex;
  background:var(--bar);
  border-top:1px solid var(--br);
  padding:6px 0 max(6px,env(safe-area-inset-bottom));
  flex-shrink:0;position:relative;z-index:20;
}
.bot-nav::before{
  content:'';position:absolute;top:-1px;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--acc),transparent);
  opacity:.4;
}
.nav-item{
  flex:1;display:flex;flex-direction:column;align-items:center;
  gap:3px;cursor:pointer;padding:4px 0;
  transition:all .18s;position:relative;
}
.nav-ico{font-size:21px;line-height:1;position:relative;}
.nav-ico .nav-badge{
  position:absolute;top:-5px;right:-9px;
  background:var(--badge);color:#fff;font-family:var(--fe);
  font-size:9px;font-weight:700;
  min-width:16px;height:16px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;padding:0 3px;
}
.nav-lbl{font-size:10px;font-weight:600;color:var(--t3);transition:color .18s;letter-spacing:.2px;}
.nav-item.active .nav-lbl{color:var(--acc);}
.nav-item.active .nav-ico{animation:navPop .3s var(--spring);}
@keyframes navPop{0%{transform:scale(.7)}60%{transform:scale(1.2)}100%{transform:scale(1)}}

/* ═══════════════════════════════════
   SCREENS
═══════════════════════════════════ */
.screen{flex:1;display:flex;flex-direction:column;overflow:hidden;animation:fadeUp .25s var(--ease);}
.screen.off{display:none;}

/* Friends */
.f-item{
  display:flex;align-items:center;gap:13px;padding:12px 16px;
  cursor:pointer;border-bottom:1px solid var(--br);
  transition:background .15s;
}
.f-item:hover{background:var(--s1);}
.f-name{font-size:15px;font-weight:700;color:var(--t0);}
.f-status{font-size:12px;color:var(--t2);margin-top:1px;}
.f-acts{display:flex;gap:6px;}

/* Discover */
.disc-feed{flex:1;overflow-y:auto;}
.disc-feed::-webkit-scrollbar{width:0;}
.post-card{
  background:var(--s0);
  margin-bottom:2px;
  border-bottom:1px solid var(--br);
  animation:fadeUp .25s var(--ease);
}
.post-head{display:flex;align-items:center;gap:10px;padding:13px 14px 8px;}
.post-author{font-size:14px;font-weight:700;color:var(--t0);}
.post-time{font-size:11px;color:var(--t3);margin-top:1px;}
.post-txt{padding:0 14px 12px;font-size:14px;color:var(--t1);line-height:1.65;}
.post-img{width:100%;max-height:300px;object-fit:cover;}
.post-acts{display:flex;border-top:1px solid var(--br);}
.post-act{
  flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
  padding:11px;font-size:13px;color:var(--t2);
  cursor:pointer;background:transparent;border:none;
  font-family:var(--fa);transition:all .15s;
}
.post-act:hover{background:var(--s1);}
.post-act.liked{color:var(--badge);}

.disc-fab{
  position:absolute;bottom:75px;left:20px;
  width:52px;height:52px;border-radius:50%;
  background:var(--acc);color:var(--bme-t);
  border:none;cursor:pointer;font-size:24px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(0,0,0,.35);
  transition:all .18s;z-index:15;
}
.disc-fab:hover{transform:scale(1.1) rotate(10deg);}

/* Me / Profile */
.profile-scroll{flex:1;overflow-y:auto;}
.profile-scroll::-webkit-scrollbar{width:0;}
.profile-hero{
  background:var(--s0);
  padding:28px 16px 0;
  display:flex;flex-direction:column;align-items:center;
  border-bottom:1px solid var(--br);
  position:relative;overflow:hidden;
}
.profile-hero::before{
  content:'';position:absolute;
  width:280px;height:280px;border-radius:50%;
  background:radial-gradient(circle,var(--acc) 0%,transparent 70%);
  top:-140px;left:50%;transform:translateX(-50%);
  opacity:.1;filter:blur(30px);pointer-events:none;
}
.pav-wrap{position:relative;cursor:pointer;margin-bottom:14px;}
.pav-edit{
  position:absolute;bottom:2px;right:2px;
  width:26px;height:26px;border-radius:50%;
  background:var(--acc);color:var(--bme-t);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;border:2px solid var(--s0);
}
.pname{font-size:21px;font-weight:800;color:var(--t0);letter-spacing:-.5px;margin-bottom:4px;}
.pphone{font-size:13px;color:var(--t3);margin-bottom:4px;}
.pstatus{font-size:13px;color:var(--t2);margin-bottom:18px;}
.pstats{display:flex;width:100%;border-top:1px solid var(--br);}
.pstat{flex:1;padding:13px 0;text-align:center;cursor:pointer;transition:background .15s;}
.pstat:hover{background:var(--s1);}
.pstat-n{font-family:var(--fe);font-size:19px;font-weight:700;color:var(--acc);}
.pstat-l{font-size:11px;color:var(--t3);margin-top:2px;}

.menu-grp{background:var(--s0);margin-bottom:8px;}
.menu-item{
  display:flex;align-items:center;gap:13px;padding:14px 16px;
  cursor:pointer;border-bottom:1px solid var(--br);
  transition:background .15s;
}
.menu-item:last-child{border-bottom:none;}
.menu-item:hover{background:var(--s1);}
.menu-ico{
  width:36px;height:36px;border-radius:11px;
  display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;
}
.menu-lbl{flex:1;font-size:15px;color:var(--t0);font-weight:500;}
.menu-val{font-size:13px;color:var(--t3);margin-left:6px;}
.menu-arr{font-size:14px;color:var(--t3);}

/* ═══════════════════════════════════
   BOTTOM SHEETS
═══════════════════════════════════ */
.overlay{
  position:fixed;inset:0;z-index:400;
  display:flex;align-items:flex-end;justify-content:center;
  background:transparent;pointer-events:none;
  transition:background .25s;
}
.overlay.on{background:rgba(0,0,0,.6);pointer-events:all;backdrop-filter:blur(6px);}
.sheet{
  background:var(--s1);
  border-radius:24px 24px 0 0;
  width:100%;max-height:90vh;
  display:flex;flex-direction:column;
  transform:translateY(110%);
  transition:transform .32s var(--ease);
  overflow:hidden;
  box-shadow:0 -6px 40px rgba(0,0,0,.5);
  border:1px solid var(--br);border-bottom:none;
}
.overlay.on .sheet{transform:translateY(0);}
.sh-handle{width:36px;height:4px;border-radius:2px;background:var(--s3);margin:12px auto 0;}
.sh-head{
  padding:14px 18px;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--br);flex-shrink:0;
}
.sh-title{font-size:16px;font-weight:800;color:var(--t0);letter-spacing:-.3px;}
.sh-close{
  width:28px;height:28px;border-radius:9px;
  background:var(--s2);border:1px solid var(--br);
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:13px;color:var(--t2);transition:all .15s;
}
.sh-close:hover{background:var(--s3);}
.sh-body{padding:18px;overflow-y:auto;flex:1;}
.sh-body::-webkit-scrollbar{width:0;}

/* sheet tabs */
.sh-tabs{display:flex;border-bottom:1px solid var(--br);margin:-18px -18px 18px;}
.sh-tab{flex:1;padding:13px;text-align:center;font-size:13px;font-weight:700;color:var(--t3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s;}
.sh-tab.on{color:var(--acc);border-bottom-color:var(--acc);}

/* form fields */
.field{margin-bottom:16px;}
.f-lbl{font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.9px;margin-bottom:7px;}
.f-in{width:100%;padding:12px 14px;background:var(--s2);border:1.5px solid var(--br);border-radius:13px;font-family:var(--fa);font-size:14px;color:var(--t0);outline:none;transition:all .18s;}
.f-in:focus{border-color:var(--acc);background:var(--s0);}
.f-in::placeholder{color:var(--t3);}

.color-row{display:flex;gap:9px;flex-wrap:wrap;margin-top:4px;}
.c-dot{width:28px;height:28px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .15s;}
.c-dot.on{border-color:var(--t0);transform:scale(1.15);}

.sh-btn{
  width:100%;padding:13px;background:var(--acc);color:var(--bme-t);
  border:none;border-radius:13px;font-family:var(--fa);font-size:15px;font-weight:700;
  cursor:pointer;transition:all .18s;margin-top:4px;letter-spacing:.3px;
}
.sh-btn:hover{opacity:.9;transform:translateY(-1px);}
.sh-btn:active{transform:scale(.97);}
.sh-btn.sec{background:var(--s2);color:var(--t1);border:1px solid var(--br);margin-top:9px;}
.sh-btn.danger{background:transparent;color:#EF4444;border:1.5px solid #EF4444;margin-top:9px;}

/* QR */
.qr-wrap{display:flex;flex-direction:column;align-items:center;gap:12px;padding:10px 0;}
.qr-lbl{font-size:12px;color:var(--t3);text-align:center;max-width:200px;line-height:1.6;}
.qr-wrap canvas{border-radius:14px;}

/* Scan */
.scan-area{display:flex;flex-direction:column;align-items:center;gap:16px;padding:8px 0;}
.scan-frame{width:220px;height:220px;border-radius:18px;overflow:hidden;position:relative;background:#000;box-shadow:0 6px 30px rgba(0,0,0,.6);}
.scan-frame video{width:100%;height:100%;object-fit:cover;}
.scan-corners{position:absolute;inset:0;pointer-events:none;}
.scan-corners::before,.scan-corners::after,.sc-tl,.sc-br{content:'';position:absolute;width:30px;height:30px;border-color:var(--acc);border-style:solid;}
.scan-corners::before{top:12px;right:12px;border-width:3px 3px 0 0;border-radius:0 8px 0 0;}
.scan-corners::after{top:12px;left:12px;border-width:3px 0 0 3px;border-radius:8px 0 0 0;}
.sc-tl{bottom:12px;right:12px;border-width:0 3px 3px 0;border-radius:0 0 8px 0;}
.sc-br{bottom:12px;left:12px;border-width:0 0 3px 3px;border-radius:0 0 0 8px;}
.scan-line{position:absolute;left:16px;right:16px;height:2px;background:var(--acc);box-shadow:0 0 10px var(--acc);animation:scanMove 2s ease-in-out infinite;}
@keyframes scanMove{0%,100%{top:16px}50%{top:calc(100% - 16px)}}

/* post compose */
.compose-ta{width:100%;border:none;background:transparent;font-family:var(--fa);font-size:15px;color:var(--t0);resize:none;outline:none;min-height:110px;line-height:1.65;}
.compose-ta::placeholder{color:var(--t3);}
.compose-img{width:100%;max-height:200px;object-fit:cover;border-radius:13px;margin:12px 0;display:none;}
.img-attach{display:flex;align-items:center;gap:8px;padding:12px 0;border-top:1px solid var(--br);border-bottom:1px solid var(--br);font-size:14px;color:var(--t2);cursor:pointer;margin-bottom:12px;}

/* theme picker */
.theme-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
.t-opt{border-radius:14px;padding:14px 12px;cursor:pointer;border:2px solid transparent;text-align:center;transition:all .2s;background:var(--s2);}
.t-opt:hover{transform:scale(1.03);}
.t-opt.on{border-color:var(--acc);}
.t-prev{display:flex;gap:6px;justify-content:center;margin-bottom:9px;}
.t-swatch{width:14px;height:14px;border-radius:50%;}
.t-name{font-size:13px;font-weight:700;color:var(--t0);}
.lang-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;}
.lang-btn{padding:8px 16px;border-radius:10px;cursor:pointer;font-size:13px;font-weight:600;border:1.5px solid var(--br);background:var(--s2);color:var(--t2);transition:all .18s;}
.lang-btn.on{background:var(--acc);color:var(--bme-t);border-color:var(--acc);}

/* edit profile */
.ep-av{
  display:flex;flex-direction:column;align-items:center;
  margin-bottom:22px;cursor:pointer;
}
.ep-hint{font-size:12px;color:var(--t3);margin-top:8px;}

/* Call log */
.cl-item{display:flex;align-items:center;gap:13px;padding:12px 16px;border-bottom:1px solid var(--br);cursor:pointer;transition:background .15s;}
.cl-item:hover{background:var(--s1);}
.cl-name{font-size:15px;font-weight:700;}
.cl-meta{font-size:12px;color:var(--t2);margin-top:2px;}

/* Friend requests */
.freq-card{
  background:var(--s1);border:1.5px solid var(--br);
  border-radius:18px;padding:16px;margin:10px 14px;
  animation:fadeUp .25s var(--ease);
}
.freq-head{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.freq-name{font-size:15px;font-weight:800;color:var(--t0);}
.freq-sub{font-size:12px;color:var(--t2);margin-top:2px;}
.freq-row{display:flex;gap:8px;margin-bottom:8px;}
.freq-btn{
  flex:1;padding:10px 8px;border-radius:11px;font-family:var(--fa);
  font-size:13px;font-weight:700;cursor:pointer;border:none;
  transition:all .18s;
}
.freq-btn.accept{background:var(--acc);color:var(--bme-t);}
.freq-btn.decline{background:var(--s3);color:var(--t2);border:1px solid var(--br);}
.freq-btn.block{background:transparent;color:#EF4444;border:1.5px solid rgba(239,68,68,.4);}
.freq-toggle{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 13px;background:var(--s2);border-radius:12px;
  border:1px solid var(--br);margin-top:2px;
}
.freq-tlbl{font-size:13px;color:var(--t1);font-weight:500;flex:1;}
.freq-tsub{font-size:11px;color:var(--t3);margin-top:2px;}
.tog{
  width:44px;height:26px;border-radius:13px;
  background:var(--s3);cursor:pointer;position:relative;
  transition:background .2s;border:none;flex-shrink:0;
}
.tog.on{background:var(--acc);}
.tog::after{
  content:'';position:absolute;top:3px;right:3px;
  width:20px;height:20px;border-radius:50%;background:#fff;
  transition:transform .2s var(--spring);
  box-shadow:0 1px 4px rgba(0,0,0,.3);
}
.tog.on::after{transform:translateX(-18px);}
.sbadge{
  font-size:10px;font-weight:700;padding:2px 8px;
  border-radius:10px;display:inline-block;
}
.sbadge.pending{background:rgba(245,158,11,.15);color:#D97706;}
.sbadge.blocked{background:rgba(239,68,68,.12);color:#EF4444;}
.req-sep{
  display:flex;align-items:center;gap:10px;padding:8px 14px;
  font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;
}
.req-sep::before,.req-sep::after{content:'';flex:1;height:1px;background:var(--br);}

/* Toast */
.toast{
  position:fixed;top:18px;left:50%;
  transform:translateX(-50%) translateY(-80px);
  background:var(--s2);color:var(--t0);
  padding:10px 20px;border-radius:30px;
  font-size:13px;font-weight:600;
  border:1px solid var(--br);box-shadow:var(--shlg);
  z-index:9999;pointer-events:none;
  transition:transform .28s var(--spring);white-space:nowrap;
}
.toast.show{transform:translateX(-50%) translateY(0);}

/* Swipe hint */
.swipe-hint{
  position:fixed;bottom:80px;left:50%;
  transform:translateX(-50%) translateY(20px);
  background:rgba(0,0,0,.75);color:#fff;
  font-size:12px;padding:8px 18px;border-radius:20px;
  pointer-events:none;opacity:0;transition:all .3s;
  white-space:nowrap;z-index:50;
}
.swipe-hint.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* Avatar color palette */
.A{background:#EF4444;} .B{background:#3B82F6;} .C{background:#10B981;}
.D{background:#8B5CF6;} .E{background:#F59E0B;} .F{background:#EC4899;}
.G{background:#06B6D4;} .H{background:#6366F1;} .I{background:#F97316;}

/* Country picker */
.lf-row{position:relative;}
.country-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;cursor:pointer;
  transition:background .13s;border-bottom:1px solid var(--br);
}
.country-item:last-child{border-bottom:none;}
.country-item:hover{background:var(--s2);}
.country-item.selected{background:var(--acc3);}
.ci-flag{font-size:20px;flex-shrink:0;}
.ci-name{font-size:13px;color:var(--t1);flex:1;}
.ci-dial{font-family:var(--fe);font-size:12px;color:var(--t3);font-weight:600;}
#countryDropdown.open{display:flex!important;}
</style>
</head>
<body data-theme="gold">

