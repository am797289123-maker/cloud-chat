      <button class="login-btn" id="lBtn">دخول ←</button>
      <div class="login-terms" id="loginTerms">بالمتابعة توافق على شروط الاستخدام</div>
    </div>
  </div>
</div>

<!-- ══════ MAIN ══════ -->
<div id="shell">
<div id="mainWrap">

  <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative;">

    <!-- SLIDE WRAP -->
    <div class="slide-wrap" id="sw">

      <!-- LIST PANEL -->
      <div class="panel" id="pList">

        <!-- CHATS -->
        <div class="screen" id="sChats">
          <div class="topbar">
            <div class="tb-title" id="tbTitleChats">Pulse</div>
